# Google OAuth — fill in from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost/auth/callback

# JWT
JWT_SECRET=supersecretjwtkey_changethisinproduction
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# User Service DB
USER_DB_URL=postgresql+asyncpg://user_admin:user_pass@user-db:5432/userdb

# Deck Service DB
DECK_DB_URL=postgresql+asyncpg://deck_admin:deck_pass@deck-db:5432/deckdb

# Redis
REDIS_URL=redis://redis:6379

# Internal service URLs (used inside Docker network)
DECK_SERVICE_URL=http://deck-service:8001
USER_SERVICE_URL=http://user-service:8000
QUIZ_SERVICE_URL=http://quiz-service:8002
